{
  "name": "paste-sarl",
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "____module": "index.ts",
  "private": true,
  "scripts": {
    "clean": "rm -rf ./dist",
    "bundle": "bun build ./src/index.html --outdir=dist --env=PUBLIC_*",
    "build": "bun run clean && bun run bundle",
    "dev": "bun --watch ./src/index.html"
  },
  "type": "module",
  "dependencies": {
    "@fontsource-variable/chivo-mono": "^5.2.8",
    "@fontsource-variable/martian-mono": "^5.2.7",
    "@fontsource/sniglet": "^5.2.8",
    "lz-string": "^1.5.0"
  }
}
